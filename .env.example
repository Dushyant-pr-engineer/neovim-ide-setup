# Copy this file to .env and replace the placeholder values with your own.
#   cp .env.example .env
#
# .env is git-ignored — never commit real secrets. Add any new secrets this
# project needs to both .env.example (placeholder) and .env (real value).

# WakaTime API key, used by the vim-wakatime plugin for coding time tracking.
# Find yours at https://wakatime.com/api-key
WAKATIME_API_KEY=your-wakatime-api-key-here
