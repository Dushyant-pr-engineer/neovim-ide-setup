# Template for ~/.zshrc.local — copy to ~/.zshrc.local and fill in.
# install.sh copies this to ~/.zshrc.local automatically if that file is absent.
#
# This file is sourced at the END of the repo-managed ~/.zshrc, after oh-my-zsh
# loads and ~/.env is sourced. Put machine-specific config ONLY here — it lives
# in your home directory and is NEVER committed to git.
#
# Shared secrets (API keys, test credentials) go in .env — see .env.example.

# --- PHP build flags (adjust version to what you have installed) ---------------
# export LDFLAGS="-L/opt/homebrew/opt/php@8.5/lib"
# export CPPFLAGS="-I/opt/homebrew/opt/php@8.5/include"

# --- PATH (machine-specific) --------------------------------------------------
# export PATH="/opt/homebrew/bin:$PATH"
# export PATH="$HOME/go/bin:$PATH"
# export PATH="$HOME/.local/bin:$PATH"

# --- NVM ----------------------------------------------------------------------
# export NVM_DIR="$HOME/.nvm"
# [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
# [ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"

# --- Project paths (machine-specific) -----------------------------------------
# export POLICYR_PATH="$HOME/src/ops/policyr"  # PolicyR project root (used by tmux/policyr-session.sh, aliases)

# --- Docker CLI completions ---------------------------------------------------
# fpath=($HOME/.docker/completions $fpath)
# autoload -Uz compinit
# compinit
