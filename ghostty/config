# Font
font-family = JetBrainsMono Nerd Font
font-size = 16
font-thicken = true

# Window
window-padding-x = 12
window-padding-y = 12
window-padding-balance = true
background-opacity = 1
unfocused-split-opacity = 0.6

# macOS
macos-option-as-alt = left
shell-integration = detect
window-save-state = always

# Theme (Tokyo Night to match the Neovim colorscheme)
theme = "GitHub Dark"

# Cursor / mouse
cursor-style = bar
cursor-style-blink = true
mouse-hide-while-typing = true
copy-on-select = clipboard

# Let Cmd+A reach the running app (e.g. Neovim) instead of Ghostty's own
# "select entire terminal window" text selection.
keybind = cmd+a=unbind

# Keep true 256-color terminfo for tmux
term = xterm-256color
